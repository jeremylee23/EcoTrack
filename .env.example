# ============================================================
# .env.example — EcoTrack LINE Bot Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Found at: https://app.supabase.com/project/<YOUR_PROJECT>/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Upstash Redis ─────────────────────────────────────────────
# Found at: https://console.upstash.com/redis
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_redis_token_here

# ── LINE Messaging API ────────────────────────────────────────
# Found at: https://developers.line.biz/console/channel/<channelId>/basic
LINE_CHANNEL_ID=2010097698
LINE_CHANNEL_SECRET=0a7aa640113bd9eb23761e177ef6aeb0
LINE_CHANNEL_ACCESS_TOKEN=your_long_lived_access_token_here

# ── HCCG API (新竹市政府清運網) ───────────────────────────────
# Default: https://7966.hccg.gov.tw/WEB/_IMP/API/CleanWeb
# No API key required — public endpoint discovered via reverse engineering
HCCG_API_BASE_URL=https://7966.hccg.gov.tw/WEB/_IMP/API/CleanWeb

# ── Cron Job Security ─────────────────────────────────────────
# Set a random secret; pass as Authorization: Bearer <secret> to call cron manually
CRON_SECRET=your_random_secret_here
